# ═══════════════════════════════════════════════════════════
# Q-SpecTrum LLM Configuration / LLM 配置
# ═══════════════════════════════════════════════════════════
# 复制此文件为 .env 并填入你的 API Key:
#   copy .env.template .env    (Windows)
#   cp .env.template .env      (Mac/Linux)
#
# 然后运行: python run.py
# ═══════════════════════════════════════════════════════════

# --- 选择 LLM 提供商 (选一个取消注释) ---
# QSPECTRUM_LLM=auto          # 自动检测 (默认)
# QSPECTRUM_LLM=openai        # OpenAI GPT-4o
# QSPECTRUM_LLM=anthropic     # Anthropic Claude
# QSPECTRUM_LLM=deepseek      # DeepSeek (性价比高)
# QSPECTRUM_LLM=openrouter    # OpenRouter (100+模型)
# QSPECTRUM_LLM=ollama        # Ollama 本地模型 (免费)
# QSPECTRUM_LLM=mock          # 模拟模式 (无需API Key)

# --- OpenAI ---
# OPENAI_API_KEY=sk-xxxxx
# OPENAI_MODEL=gpt-4o
# OPENAI_BASE_URL=https://api.openai.com/v1

# --- Anthropic Claude ---
# ANTHROPIC_API_KEY=sk-ant-xxxxx
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# --- DeepSeek ---
# DEEPSEEK_API_KEY=sk-xxxxx
# DEEPSEEK_MODEL=deepseek-chat

# --- OpenRouter (100+ models) ---
# OPENROUTER_API_KEY=sk-or-xxxxx
# OPENROUTER_MODEL=anthropic/claude-sonnet-4

# --- Ollama (本地, 免费) ---
# OLLAMA_MODEL=llama3
# OLLAMA_BASE_URL=http://localhost:11434

# --- Ghost Channel (可选) ---
# GHOST_CHANNEL_KEY=your-activation-key

# --- DeerFlow (可选, 外部 AI Agent 集成) ---
# DEERFLOW_API_URL=http://localhost:8000
